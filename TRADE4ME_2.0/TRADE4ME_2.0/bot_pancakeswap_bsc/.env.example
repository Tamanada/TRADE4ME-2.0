# .env.example — Copy to .env and fill in your real values
# NEVER commit .env to GitHub!

# ── Bot wallet (dedicated hot wallet — NEVER your main wallet) ────────────────
PRIVATE_KEY=0xTA_CLE_PRIVEE_ICI
WALLET_ADDRESS=0xTON_ADRESSE_BOT

# ── BSC RPC — use a private node in production for speed ─────────────────────
# Free  : https://bsc-dataseed1.binance.org/
# Paid  : QuickNode, Ankr, NodeReal (recommended for < 300ms latency)
BSC_RPC_URL=https://bsc-dataseed1.binance.org/

# ── Smart contract (fill after deploying ArbBot.sol) ─────────────────────────
ARB_CONTRACT_ADDRESS=

# ── Profit sweeper — auto-transfer profits to cold wallet ────────────────────
# Set AUTO_SWEEP=true to enable automatic transfers
AUTO_SWEEP=false

# Cold wallet address (Ledger, Trezor, or any safe wallet)
# Profits above KEEP_CAPITAL_BNB + SWEEP_THRESHOLD_BNB will be sent here
COLD_WALLET_ADDRESS=0xTON_COLD_WALLET

# Amount of BNB to always keep on the bot wallet for trading capital
KEEP_CAPITAL_BNB=0.5

# Sweep is triggered when balance exceeds KEEP_CAPITAL + this threshold
# Example: KEEP=0.5, THRESHOLD=0.2 → sweep when balance > 0.7 BNB
#          Bot keeps 0.5 BNB, transfers 0.2+ BNB to cold wallet
SWEEP_THRESHOLD_BNB=0.2

# ── Bot behaviour ─────────────────────────────────────────────────────────────
# DRY_RUN=true  → simulate only, no real transactions sent
# DRY_RUN=false → live trading (only after thorough testnet testing!)
DRY_RUN=true
